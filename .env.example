# pgui - Server Configuration
# Configure one or more PostgreSQL servers using numbered environment variables.
# The app scans for DB_1_*, DB_2_*, DB_3_*, etc. and stops at the first gap.
# Databases on each server are discovered automatically via the `postgres` maintenance database.

# Server 1
DB_1_NAME=production
DB_1_HOST=localhost
DB_1_PORT=5432
DB_1_USERNAME=readonly
DB_1_PASSWORD=secret
DB_1_SSL=false

# Server 2 (optional)
# DB_2_NAME=staging
# DB_2_HOST=staging-db.internal
# DB_2_PORT=5432
# DB_2_USERNAME=readonly
# DB_2_PASSWORD=secret2
# DB_2_SSL=true
